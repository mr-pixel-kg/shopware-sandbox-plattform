# docker socket path
# macOS with Docker Desktop: /Users/<username>/.docker/run/docker.sock
# linux / Docker in Docker: /var/run/docker.sock
DOCKER_SOCKET_PATH=/var/run/docker.sock

# postgres credentials
POSTGRES_USER=mrpix_sandbox
POSTGRES_PASSWORD=change-me
POSTGRES_DB=mrpix_sandbox

# frontend backend (used at build time and runtime)
VITE_BACKEND_URL=http://localhost:8080
